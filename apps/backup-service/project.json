{
    "name": "backup-service",
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "projectType": "application",
    "targets": {
        "lint": {
            "executor": "nx:run-commands",
            "options": {
                "command": "echo no linting"
            }
        },
        "deploy": {
            "executor": "nx:run-commands",
            "options": {
                "commands": [
                    "copyfiles ./apps/backup-service/run_backups -u 2 ./deploy/etc/cron.d",
                    "copyfiles ./apps/backup-service/rsnapshot.conf -u 1 ./deploy/opt/monorepo"
                ]
            }
        }
    },
    "tags": ["backup-service"]
}
