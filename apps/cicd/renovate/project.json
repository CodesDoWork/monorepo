{
    "name": "cicd-renovate",
    "$schema": "../../../node_modules/nx/schemas/project-schema.json",
    "projectType": "application",
    "targets": {
        "lint": {
            "executor": "nx:run-commands",
            "options": {
                "command": "echo no linting"
            }
        },
        "deploy-command": {
            "executor": "nx:run-commands",
            "options": {
                "command": "echo docker compose up --pull always renovate >> ./deploy/opt/monorepo/deploy-commands.sh"
            }
        },
        "deploy": {
            "executor": "nx:run-commands",
            "options": {
                "command": "copyfiles ./apps/cicd/renovate/config.js ./deploy/opt/monorepo"
            }
        }
    },
    "tags": []
}
