{
    "name": "just-site",
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "sourceRoot": "apps/just-site/src",
    "projectType": "application",
    "targets": {
        "build": {
            "executor": "nx:run-commands",
            "options": {
                "command": "vite build --config vite-config.ts",
                "cwd": "apps/just-site"
            }
        },
        "serve": {
            "executor": "nx:run-commands",
            "options": {
                "command": "vite dev --config vite-config.ts",
                "cwd": "apps/just-site"
            }
        },
        "preview": {
            "executor": "nx:run-commands",
            "options": {
                "command": "vite preview --config vite-config.ts",
                "cwd": "apps/just-site"
            }
        },
        "pre-build": {
            "executor": "nx:run-commands",
            "options": {
                "command": "node copy-env.js",
                "cwd": "apps/just-site"
            }
        },
        "lint": {
            "executor": "@nx/eslint:lint",
            "outputs": ["{options.outputFile}"],
            "options": {
                "lintFilePatterns": ["apps/just-site/**/*.{ts,svelte,spec.ts}"]
            }
        },
        "check": {
            "executor": "nx:run-commands",
            "options": {
                "command": "svelte-check",
                "cwd": "apps/just-site"
            }
        },
        "build-image": {
            "executor": "nx:run-commands",
            "options": {
                "command": "docker compose build just-site --push",
                "cwd": "apps"
            }
        },
        "run-image": {
            "executor": "nx:run-commands",
            "options": {
                "command": "docker compose up -d just-site",
                "cwd": "apps"
            }
        }
    },
    "tags": ["just-site"]
}
