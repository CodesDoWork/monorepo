{
    "name": "music-service",
    "$schema": "../../../node_modules/nx/schemas/project-schema.json",
    "projectType": "application",
    "targets": {
        "pre-build": {
            "executor": "nx:run-commands",
            "options": {
                "command": "node -e \"fs.writeFileSync('.env', '');\""
            }
        },
        "lint": {
            "executor": "nx:run-commands",
            "options": {
                "command": "echo no linting"
            }
        }
    },
    "build-image": {
        "executor": "nx:run-commands",
        "options": {
            "command": "docker compose build music-service --push"
        }
    },
    "tags": []
}
