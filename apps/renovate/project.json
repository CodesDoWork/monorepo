{
    "name": "renovate",
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "projectType": "application",
    "targets": {
        "lint": {
            "executor": "nx:run-commands",
            "options": {
                "command": "echo no linting"
            }
        },
        "deploy-command": {
            "executor": "nx:run-commands",
            "options": {
                "command": "echo docker compose -f /opt/monorepo/docker-compose.yml --env-file /opt/monorepo/.env up --pull always renovate >> deploy-commands.sh"
            }
        },
        "deploy": {
            "executor": "nx:run-commands",
            "options": {
                "command": "copyfiles ./apps/renovate/config.js -u 1 ./deploy/opt/monorepo"
            }
        }
    },
    "tags": []
}
