{
    "name": "nx-containers-e2e",
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "projectType": "application",
    "sourceRoot": "e2e/nx-containers-e2e/src",
    "targets": {
        "e2e": {
            "executor": "@nrwl/nx-plugin:e2e",
            "options": {
                "target": "nx-containers:build",
                "jestConfig": "e2e/nx-containers-e2e/jest.config.ts"
            }
        },
        "lint": {
            "executor": "@nrwl/linter:eslint",
            "outputs": ["{options.outputFile}"],
            "options": {
                "lintFilePatterns": ["e2e/nx-containers-e2e/**/*.ts"]
            }
        }
    },
    "tags": [],
    "implicitDependencies": ["nx-containers"]
}
