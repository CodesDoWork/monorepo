{
    "name": "just-cloud",
    "$schema": "../../../node_modules/nx/schemas/project-schema.json",
    "sourceRoot": "packages/just/cloud",
    "projectType": "application",
    "targets": {
        "deploy": {
            "executor": "@cdw/monorepo/nx-plugins-ci:deploy",
            "options": {
                "enabled": false,
                "files": ["configuration.nix"],
                "commands": [
                    "sudo mv -vf configuration.nix /etc/nixos/configuration.nix",
                    "sudo nixos-rebuild switch --upgrade"
                ]
            },
            "configurations": {
                "manual": {
                    "enabled": true
                }
            }
        }
    },
    "tags": []
}
