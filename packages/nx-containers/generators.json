{
    "$schema": "http://json-schema.org/schema",
    "name": "nx-containers",
    "version": "0.0.1",
    "generators": {
        "base": {
            "factory": "./src/generators/base/generator",
            "schema": "./src/generators/base/schema.json",
            "description": "Creates a base.Dockerfile to extend from"
        },
        "workspace": {
            "factory": "./src/generators/workspace/generator",
            "schema": "./src/generators/workspace/schema.json",
            "description": "Creates a Dockerfile for your workspace to use with your apps"
        },
        "node": {
            "factory": "./src/generators/node/generator",
            "schema": "./src/generators/node/schema.json",
            "description": "Creates Dockerfiles for your app"
        }
    }
}
