{
    "$schema": "http://json-schema.org/schema",
    "cli": "nx",
    "$id": "NxContainers",
    "title": "",
    "type": "object",
    "properties": {
        "nodeVersion": {
            "type": "string",
            "description": "Node version for base image",
            "alias": "v"
        },
        "organization": {
            "type": "string",
            "description": "Organization is used as prefix for image names",
            "alias": "o"
        },
        "dockerCompose": {
            "type": "boolean",
            "description": "Whether to use a docker-compose.yml config file or not",
            "alias": "c"
        }
    },
    "required": []
}
