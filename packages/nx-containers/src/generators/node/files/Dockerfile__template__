FROM <%= workspaceImage %> AS builder
FROM <%= baseImage %> AS base

FROM base AS deps
WORKDIR /app

COPY  --from=builder /app/dist/apps/<%= appName %>/package.json .
RUN npm i


FROM base AS runner
WORKDIR /app

ARG VERSION

ENV NODE_ENV production
ENV PACKAGE_VERSION $VERSION

COPY --from=builder /app/dist/apps/<%= appName %> .
COPY --from=deps /app/node_modules ./node_modules

ENTRYPOINT node .
