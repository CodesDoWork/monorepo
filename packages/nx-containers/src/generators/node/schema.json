{
    "$schema": "http://json-schema.org/schema",
    "cli": "nx",
    "$id": "NxContainers",
    "title": "",
    "type": "object",
    "properties": {
        "appName": {
            "type": "string",
            "description": "App to containerize",
            "$default": {
                "$source": "argv",
                "index": 0
            },
            "x-prompt": "What app would you like to containerize?"
        },
        "organization": {
            "type": "string",
            "description": "Organization is used as prefix for image names",
            "alias": "o"
        },
        "dockerCompose": {
            "type": "boolean",
            "description": "Whether to use a docker-compose.yml config file or not",
            "alias": "c"
        }
    },
    "required": ["appName"]
}
