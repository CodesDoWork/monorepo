{
    "name": "nx-containers",
    "$schema": "../../../node_modules/nx/schemas/project-schema.json",
    "sourceRoot": "packages/nx-plugins/nx-containers/src",
    "projectType": "library",
    "targets": {
        "build": {
            "executor": "@nrwl/js:tsc",
            "outputs": ["{options.outputPath}"],
            "options": {
                "outputPath": "dist/packages/nx-plugins/nx-containers",
                "main": "packages/nx-plugins/nx-containers/src/index.ts",
                "tsConfig": "packages/nx-plugins/nx-containers/tsconfig.lib.json",
                "assets": [
                    "packages/nx-plugins/nx-containers/*.md",
                    {
                        "input": "./packages/nx-plugins/nx-containers/src",
                        "glob": "**/!(*.ts)",
                        "output": "./src"
                    },
                    {
                        "input": "./packages/nx-plugins/nx-containers/src",
                        "glob": "**/*.d.ts",
                        "output": "./src"
                    },
                    {
                        "input": "./packages/nx-plugins/nx-containers",
                        "glob": "generators.json",
                        "output": "."
                    },
                    {
                        "input": "./packages/nx-plugins/nx-containers",
                        "glob": "executors.json",
                        "output": "."
                    }
                ]
            }
        },
        "lint": {
            "executor": "@nrwl/linter:eslint",
            "outputs": ["{options.outputFile}"],
            "options": {
                "lintFilePatterns": [
                    "packages/nx-plugins/nx-containers/**/*.ts",
                    "packages/nx-plugins/nx-containers/generators.json",
                    "packages/nx-plugins/nx-containers/executors.json",
                    "packages/nx-plugins/nx-containers/package.json"
                ]
            }
        },
        "test": {
            "executor": "@nrwl/jest:jest",
            "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
            "options": {
                "jestConfig": "packages/nx-plugins/nx-containers/jest.config.ts",
                "passWithNoTests": true
            },
            "configurations": {
                "ci": {
                    "ci": true,
                    "codeCoverage": true
                }
            }
        },
        "publish": {
            "executor": "nx:run-commands",
            "options": {
                "command": "npm publish dist/packages/nx-plugins/nx-containers"
            }
        }
    },
    "tags": []
}
