FROM <%= baseImage %> AS workspace
WORKDIR /app

<%- installGit %>

RUN npm i -g @antfu/ni
<%- preInstall -%>

COPY package.json .
COPY *lock* .
RUN ni
<%- postInstall -%>
<%- preCopy -%>

COPY . .
<%- preChecks -%>

RUN npx nx format:check
RUN npx nx run-many -t lint -c production
RUN npx nx run-many -t test -c production
RUN npx nx run-many -t build -c production
<%- end -%>